# Configuración del Metabolismo (Holisto Seed)

# --- Nucleo de Consciencia (Google Gemini) ---
GEMINI_API_KEY=tu_api_key_aqui

# --- Memoria Exocortex (Qdrant) ---
# Para usar Qdrant Local (Recomendado para portabilidad absoluta):
# QDRANT_URL=./PHENOTYPE/SYSTEM/MEMORIA/qdrant
# Para usar Qdrant Cloud (Requiere API Key):
# QDRANT_URL=https://xxxxxxxx.gcp.cloud.qdrant.io:6333
# QDRANT_API_KEY=tu_qdrant_api_key

QDRANT_URL=./PHENOTYPE/SYSTEM/MEMORIA/qdrant
QDRANT_COLLECTION=terroir_memory_frugal

# --- Topologia del Terroir ---
# Estas rutas suelen ser relativas a la raiz del Orquestador
PATH_TO_PHENOTYPE=./PHENOTYPE
PATH_TO_GENOTYPE=./PROYECTOS/Evolucion_Terroir/Holisto_Seed

# --- Niveles de Registro ---
LOG_LEVEL=INFO
