# 🌿 Holisto Seed: System Environment Template
# Rename this file to .env and configure your credentials.

# --- 🧠 BRAIN (Neural Engine) ---
# Your API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSy...

# --- 💾 MEMORY (Exocortex / Vector DB) ---
# Connection details for your Qdrant instance.
# Cloud: https://cluster-id.us-east4-0.gcp.cloud.qdrant.io
# Local: http://localhost:6333
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# --- 📡 SENSES (Ubiquity / Telegram) ---
# To enable El Vigía bot. Get your token from @BotFather on Telegram.
TELEGRAM_TOKEN=123456789:ABCDEF...
# Your personal Telegram User ID (to prevent others from talking to your agent).
TELEGRAM_USER_ID=7922664316

# --- ⚙️ SYSTEM (Advanced) ---
# LOG_LEVEL: INFO, DEBUG, WARNING
LOG_LEVEL=INFO
# PATH_TO_PHENOTYPE: Default is "./PHENOTYPE"
PATH_TO_PHENOTYPE=./PHENOTYPE
